#!/usr/bin/env bash
# Remove local dev skill symlinks. Restores global g-stack-gemini as the active install.
set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$REPO_ROOT/.agents/skills"

if [ ! -d "$SKILLS_DIR" ]; then
  echo "Nothing to tear down — .agents/skills/ doesn't exist."
  exit 0
fi

# Remove individual skill symlinks
removed=()
for link in "$SKILLS_DIR"/*/; do
  name="$(basename "$link")"
  [ "$name" = "g-stack-gemini" ] && continue
  if [ -L "${link%/}" ]; then
    rm "${link%/}"
    removed+=("$name")
  fi
done

# Remove the g-stack-gemini symlink
if [ -L "$SKILLS_DIR/g-stack-gemini" ]; then
  rm "$SKILLS_DIR/g-stack-gemini"
  removed+=("g-stack-gemini")
fi

# Clean up empty dirs
rmdir "$SKILLS_DIR" 2>/dev/null || true
rmdir "$REPO_ROOT/.gemini" 2>/dev/null || true

if [ ${#removed[@]} -gt 0 ]; then
  echo "Removed: ${removed[*]}"
else
  echo "No symlinks found."
fi
echo "Dev mode deactivated. Global g-stack-gemini (~/.agents/skills/g-stack-gemini) is now active."
