#!/usr/bin/env bash
# g-stack-gemini-review-read — read review log and config for dashboard
# Usage: g-stack-gemini-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval $("$SCRIPT_DIR/g-stack-gemini-slug" 2>/dev/null)
G_STACK_GEMINI_HOME="${G_STACK_GEMINI_HOME:-$HOME/.g-stack-gemini}"
cat "$G_STACK_GEMINI_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/g-stack-gemini-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
